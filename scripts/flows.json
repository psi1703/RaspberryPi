    {
        "id": "ft_3729e28a8ced",
        "type": "ui_template",
        "z": "tab1",
        "group": "grpFileTransfer",
        "name": "File Transfer panel",
        "order": 1,
        "width": 24,
        "height": 11,
        "format": "<style>\n  .ft-wrap { font-family: system-ui, sans-serif; color: #eee; }\n  .ft-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }\n  .ft-card { background: #202020; border-radius: 10px; padding: 12px; min-height: 250px; }\n  .ft-card h3 { margin: 0 0 8px; font-size: 1rem; }\n  .ft-card button, .ft-card input::file-selector-button { border: 0; border-radius: 6px; padding: 5px 9px; margin: 2px; cursor: pointer; background: #2e7d32; color: #fff; font-weight: 600; }\n  .ft-card button.danger { background: #b71c1c; }\n  .ft-list { max-height: 190px; overflow: auto; border-top: 1px solid #444; margin-top: 8px; padding-top: 6px; }\n  .ft-row { display: flex; justify-content: space-between; gap: 8px; align-items: center; border-bottom: 1px solid #333; padding: 4px 0; }\n  .ft-name { overflow-wrap: anywhere; font-size: .82rem; }\n  .ft-meta { opacity: .65; font-size: .72rem; }\n  .ft-status { margin-top: 8px; font-size: .8rem; opacity: .85; white-space: pre-wrap; }\n</style>\n\n<div class=\"ft-wrap\">\n  <div class=\"ft-grid\">\n    <div class=\"ft-card\">\n      <h3>Home Files</h3><div>/home/initbox</div>\n      <button ng-click=\"refresh('home')\">Refresh</button>\n      <form id=\"ftHomeUpload\" enctype=\"multipart/form-data\" method=\"post\" action=\"/ft/upload/home\" target=\"ftHidden\" style=\"margin-top:6px;\">\n        <input type=\"file\" name=\"file\"><button type=\"submit\">Upload</button>\n      </form>\n      <div class=\"ft-list\"><div class=\"ft-row\" ng-repeat=\"f in files.home track by f.rel\"><div><div class=\"ft-name\">{{f.type === 'dir' ? '\ud83d\udcc1 ' : '\ud83d\udcc4 '}}{{f.rel}}</div><div class=\"ft-meta\">{{f.type}} {{f.size || 0}} bytes</div></div><div ng-if=\"f.type === 'file'\"><button ng-click=\"download('home', f.rel)\">Download</button><button class=\"danger\" ng-click=\"deleteHome(f.rel)\">Delete</button></div></div></div>\n    </div>\n    <div class=\"ft-card\">\n      <h3>Runtime Files</h3><div>/usr/local/bin</div><button ng-click=\"refresh('bin')\">Refresh</button>\n      <div class=\"ft-list\"><div class=\"ft-row\" ng-repeat=\"f in files.bin track by f.rel\"><div><div class=\"ft-name\">{{f.type === 'dir' ? '\ud83d\udcc1 ' : '\ud83d\udcc4 '}}{{f.rel}}</div><div class=\"ft-meta\">{{f.type}} {{f.size || 0}} bytes</div></div><div ng-if=\"f.type === 'file'\"><button ng-click=\"download('bin', f.rel)\">Download</button></div></div></div>\n    </div>\n    <div class=\"ft-card\">\n      <h3>CAN Trace</h3><div>/usr/local/bin/CAN.trc</div><button ng-click=\"downloadCan()\">Download CAN.trc</button>\n      <form id=\"ftCanUpload\" enctype=\"multipart/form-data\" method=\"post\" action=\"/ft/upload/can\" target=\"ftHidden\" style=\"margin-top:8px;\">\n        <input type=\"file\" name=\"file\" accept=\".trc,.TRC\"><button type=\"submit\">Upload / Replace CAN.trc</button>\n      </form>\n      <div class=\"ft-status\">Upload accepts .trc files only. FMS service is restarted automatically if installed.</div>\n    </div>\n  </div>\n  <iframe name=\"ftHidden\" style=\"display:none\"></iframe><div class=\"ft-status\">{{status}}</div>\n</div>\n<script>\n(function(scope){\n  scope.files={home:[],bin:[]}; scope.status='';\n  function setStatus(s){scope.status=s;scope.$applyAsync();}\n  scope.refresh=function(area){fetch('/ft/list?area='+encodeURIComponent(area),{cache:'no-store'}).then(r=>r.json()).then(data=>{scope.files[area]=Array.isArray(data)?data:[];setStatus('Loaded '+scope.files[area].length+' item(s) from '+area+'.');}).catch(e=>setStatus('Refresh failed: '+e));};\n  scope.download=function(area,rel){window.location.href='/ft/download?area='+encodeURIComponent(area)+'&file='+encodeURIComponent(rel);};\n  scope.downloadCan=function(){window.location.href='/ft/download-can';};\n  scope.deleteHome=function(rel){if(!confirm('Delete /home/initbox/'+rel+' ?'))return;fetch('/ft/delete-home',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'file='+encodeURIComponent(rel)}).then(r=>r.text()).then(t=>{setStatus(t);scope.refresh('home');}).catch(e=>setStatus('Delete failed: '+e));};\n  document.getElementById('ftHomeUpload').addEventListener('submit',function(){setTimeout(function(){scope.refresh('home');setStatus('Home upload submitted.');},1500);});\n  document.getElementById('ftCanUpload').addEventListener('submit',function(){setTimeout(function(){setStatus('CAN.trc upload submitted.');},1500);});\n  scope.refresh('home'); scope.refresh('bin');\n})(scope);\n</script>",
