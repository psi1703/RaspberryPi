    {
        "id": "ft_94804aca01b8",
        "type": "function",
        "z": "tab1",
        "name": "home upload parse",
        "func": "const files=(msg.req&&msg.req.files)||msg.files||{};\nlet f=null;\nif(Array.isArray(files)){f=files[0];}else if(files.file){f=Array.isArray(files.file)?files.file[0]:files.file;}else{const vals=Object.values(files);f=vals.length?(Array.isArray(vals[0])?vals[0][0]:vals[0]):null;}\nif(!f){msg.statusCode=400;msg.payload='No uploaded file found.';return [null,msg];}\nconst original=String(f.originalname||f.name||f.filename||'upload.bin').split(/[\\\\/]/).pop();\nif(!original||original.startsWith('.')||original.includes('..')||/[;&|`$<>]/.test(original)){msg.statusCode=400;msg.payload='Unsafe upload filename.';return [null,msg];}\nconst buf=f.buffer||f.data||msg.payload;\nif(!Buffer.isBuffer(buf)){msg.statusCode=400;msg.payload='Upload did not provide a file buffer.';return [null,msg];}\nmsg.ftOriginalName=original;\nmsg.filename='/tmp/initbox-ft-'+Date.now()+'-'+Math.random().toString(36).slice(2)+'-'+original.replace(/[^A-Za-z0-9._@+=,-]/g,'_');\nmsg.payload=buf;\nreturn [msg,null];",
